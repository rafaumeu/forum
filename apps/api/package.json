{
  "name": "@forum/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/infra/http/server.ts",
    "build": "tsup src/infra/http/server.ts --format esm --out-dir dist",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@forum/domain": "workspace:*",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "dayjs": "^1.11.7",
    "fastify": "^5.3.0",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "prisma": "^6.5.0",
    "supertest": "^7.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite-tsconfig-paths": "^5.1.3",
    "vitest": "^3.1.0"
  }
}
